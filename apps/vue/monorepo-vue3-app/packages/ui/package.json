{
  "name": "@monorepo-vue3-app/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./style.css": "./src/style.css"
  },
  "scripts": {
    "type-check": "vue-tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@monorepo-vue3-app/constants": "workspace:*",
    "@monorepo-vue3-app/utils": "workspace:*",
    "vue": "catalog:"
  },
  "devDependencies": {
    "@vue/tsconfig": "catalog:",
    "typescript": "catalog:",
    "vue-tsc": "catalog:"
  }
}
